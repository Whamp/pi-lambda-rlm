# Copy this file to .env before running the real Pi/Formal Leaf smoke tests.
# .env is intentionally gitignored; do not commit machine-specific model names or secrets.

# Required for `npm run test:pi-leaf-smoke`.
# Format: any model pattern accepted by `pi --model`, normally `<provider>/<model-id>`.
# Example placeholder for a local OpenAI-compatible provider:
#   LAMBDA_RLM_LEAF_MODEL=local-vllm/your-local-model-id
LAMBDA_RLM_LEAF_MODEL=local-vllm/your-local-model-id
