{
  "name": "pi-lambda-rlm",
  "version": "0.0.0",
  "private": false,
  "keywords": [
    "lambda-rlm",
    "pi-extension",
    "pi-package"
  ],
  "files": [
    "README.md",
    "src/",
    "examples/",
    ".pi/extensions/lambda-rlm/index.ts",
    ".pi/extensions/lambda-rlm/bridge.py",
    ".pi/extensions/lambda-rlm/prompts/",
    ".pi/extensions/lambda-rlm/prompt-templates/",
    ".pi/extensions/lambda-rlm/rlm/**/*.py",
    ".pi/extensions/lambda-rlm/rlm/LICENSE",
    ".pi/extensions/lambda-rlm/rlm/LOCAL_FORK.md"
  ],
  "type": "module",
  "scripts": {
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "test": "vitest run --exclude tests/pi-leaf-smoke.test.ts",
    "test:pi-leaf-smoke": "vitest run tests/pi-leaf-smoke.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "typebox": "^1.0.55"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.6.1",
    "vitest": "^4.0.13"
  },
  "pi": {
    "extensions": [
      ".pi/extensions/lambda-rlm/index.ts"
    ]
  }
}
